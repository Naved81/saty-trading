# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Schwab API
SCHWAB_CLIENT_ID=your_client_id_here
SCHWAB_SECRET=your_secret_here
SCHWAB_REDIRECT_URI=https://127.0.0.1
SCHWAB_TOKEN_PATH=./schwab_token.json

# Massive (Polygon.io) API
MASSIVE_API_KEY=your_api_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Database path (override default if needed)
# DB_PATH=C:\path\to\your\market_data.db
